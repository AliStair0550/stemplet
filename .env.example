# ── Stemplet miljøvariabler ──────────────────────────────────────────
# Kopiér til .env.local og udfyld. Ingen af disse committes.
#
# PÅKRÆVET for at hele appen virker (alt undtagen Apple Wallet):
#   NEXT_PUBLIC_APP_URL, DATABASE_URL, DIRECT_URL, AUTH_SECRET,
#   AUTH_RESEND_KEY, EMAIL_FROM, UPSTASH_REDIS_REST_URL/_TOKEN
# VALGFRIT: STRIPE_* (Pro-betaling) og APPLE_*/APNS_* (Apple Wallet).
# Logo-upload kræver INGEN ekstern tjeneste - det gemmes direkte.

# ── App-URL ───────────────────────────────────────────────────────────
# Bruges i links, magic mails, QR-koder og pass. Ingen skråstreg til sidst.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Database (Neon Postgres) [PÅKRÆVET] ───────────────────────────────
# DATABASE_URL er den poolede forbindelse (bruges i app'en).
# DIRECT_URL er den direkte forbindelse (bruges til migrationer).
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/stemplet?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/stemplet?sslmode=require"

# ── Auth.js (magic link login) [PÅKRÆVET] ─────────────────────────────
# Hemmelighed til sessions. Lav en med: openssl rand -base64 32
AUTH_SECRET="skift-mig-openssl-rand-base64-32"
# Resend API-nøgle til magic link login (kun virksomheder logger ind).
AUTH_RESEND_KEY="re_xxxxxxxx"
# Afsender af login-mails. Domænet i adressen SKAL være verificeret i Resend.
# Bemærk: et verificeret alius.dk dækker IKKE subdomænet stemplet.alius.dk -
# brug derfor en @alius.dk-adresse, medmindre du også verificerer subdomænet.
EMAIL_FROM="Stemplet <login@alius.dk>"

# ── Stempel-tokens [PÅKRÆVET] ─────────────────────────────────────────
# Hemmelighed til at signere engangs-stempel-tokens (JWT). Egen værdi.
# Falder tilbage til AUTH_SECRET hvis den ikke er sat.
STAMP_TOKEN_SECRET="skift-mig-endnu-en-lang-hemmelighed"

# ── Upstash Redis (rate limiting + engangs-tokens) [PÅKRÆVET] ─────────
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="xxxxxxxx"

# ── Stripe (Pro-abonnement, 99 kr./md.) [VALGFRIT] ────────────────────
# Uden disse virker alt paa Gratis-planen; Pro-knappen viser blot en besked.
STRIPE_SECRET_KEY="sk_test_xxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxx"
# Pris-id for Pro-planen (opret et recurring price på 99 kr./md. i Stripe).
STRIPE_PRO_PRICE_ID="price_xxxxxxxx"

# ── Apple Wallet (feature flag) [VALGFRIT] ────────────────────────────
# Sæt til "true" når certifikaterne nedenfor er på plads. Se README.
# Slaaet fra: kunder faar webkortet. Slaaet til: "Læg i Apple Wallet".
WALLET_ENABLED="false"
# Pass Type ID fra Apple Developer, fx pass.dk.alius.stemplet
APPLE_PASS_TYPE_ID="pass.dk.alius.stemplet"
# Team ID fra Apple Developer-kontoen (10 tegn).
APPLE_TEAM_ID="XXXXXXXXXX"
# Signer-certifikat + privat nøgle som een PEM, base64-encodet.
APPLE_PASS_CERT="base64-af-pass-pem"
# Adgangskode til den private nøgle (tom hvis ingen).
APPLE_PASS_CERT_PASSWORD=""
# Apple WWDR-certifikat som PEM, base64-encodet.
APPLE_WWDR_CERT="base64-af-wwdr-pem"
# APNs auth key (.p8) base64-encodet, til live pass-opdateringer.
APNS_KEY="base64-af-p8"
# Key ID for APNs-nøglen (10 tegn).
APNS_KEY_ID="XXXXXXXXXX"
