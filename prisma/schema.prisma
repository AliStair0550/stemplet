// Stemplet - digitalt stempelkort. Datamodel.
// Neon Postgres: DATABASE_URL er pooled, DIRECT_URL bruges til migrationer.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────
// Virksomhed
// ─────────────────────────────────────────────────────────────

enum Plan {
  FREE
  PRO
}

model Business {
  id               String     @id @default(cuid())
  name             String
  slug             String     @unique
  category         String? // branche (kode), backfilles i indstillinger
  logoUrl          String?
  primaryColor     String     @default("#2A1A10")
  textColor        String     @default("#FFFFFF")
  plan             Plan       @default(FREE)
  stripeCustomerId String?
  staffPin         String // hashet (bcrypt)
  stampCooldownMin Int        @default(15)
  apiKey           String?    @unique // til det offentlige API (Bearer + webhook-signatur)
  webhookUrl       String? // POST'es ved stempel/beloenning/indloesning
  weeklyEmailEnabled Boolean  @default(true) // ugentlig statistik-mail
  // Giv et velkomststempel ved kundens ALLERFOERSTE scan (opretter kort + 1
  // stempel). Standard FRA: foerste scan opretter KUN kortet, og stempler gives
  // derefter ved koeb. Saa er strukturen altid den samme: 1. kortet hentes,
  // 2. stempler gives ved kassen. Kan slaaes til i indstillinger.
  welcomeStampEnabled Boolean @default(false)
  // Selvbetjening: maa kunden stemple sig selv ved at scanne en roterende QR
  // (kioskmodus)? Standard FRA: kun personalet scanner kundens kort. Holder
  // butikken enkel (eet statisk tilmeldings-skilt) og loeser snyd strukturelt.
  selfScanEnabled Boolean @default(false)
  // Butikkens placering (valgfri). Saettes kortet paa Wallet-passet som en
  // "location", saa kortet dukker op paa kundens laaseskaerm, naar de er i
  // naerheden. Native Apple Wallet, butikkens bedste paamindelse. Adressen
  // indtastes (man er ikke noedvendigvis paa stedet) og geokodes til lat/lng.
  address          String?
  latitude         Float?
  longitude        Float?
  termsAcceptedAt  DateTime? // accepterede vilkaar/privatliv/DPA ved oprettelse
  // ── Prismodel / manuel fakturering (Billy, ingen Stripe endnu) ──────
  // Kortholder = antal CustomerCard-raekker for butikken (se lib/billing).
  // Fire-once-flag (KENDSGERNING: butikken har krydset 80) vs sent-flag (mailen er
  // bekraeftet leveret). Adskilt, saa et Resend-blip ikke taber varslet: en daglig
  // sweep sender igen for butikker med Warned sat men EmailSent stadig null.
  cardholderWarnedAt DateTime? // 80-kortholder-taerskel krydset (udloeses kun EEN gang)
  cardholderWarnEmailSentAt DateTime? // 80-varsel-mails bekraeftet leveret
  reached100At       DateTime? // dagen butikken foerst krydsede 100 (faktura-start-reference)
  reached100EmailSentAt DateTime? // faktura-trigger-mail til superadmin bekraeftet leveret
  proApprovedAt      DateTime? // ejeren har godkendt Pro-aftalen
  proApprovedById    String? // hvilken bruger (User.id) godkendte
  proPriceKr         Int       @default(99) // individuel maanedspris i kr (founding members mv.)
  proPriceUntil      DateTime? // udloeb for en specialpris; derefter gaelder standard 99
  lastInvoicedAt     DateTime? // sidste faktureringsdato, superadmin vedligeholder manuelt
  newSignupsPaused   Boolean   @default(false) // afvis nye kortholdere paent (kun superadmin)
  stopped            Boolean   @default(false) // superadmin har stoppet butikken (kun superadmin)
  users            User[]
  cards            Card[]
  auditLogs        AuditLog[]
  devices          Device[]
  pairingCodes     DevicePairingCode[]
  createdAt        DateTime   @default(now())
}

// ─────────────────────────────────────────────────────────────
// Kasse-enhed: en parret disk-enhed (fx iPad) med langtids-adgang til
// registeret UDEN ejer-login. Kan spaerres af ejeren. Adgangen er begraenset
// til kassen (vis QR, scan, stempel, indloes med PIN, kassemodus), aldrig
// dashboard/priser/fakturering.
// ─────────────────────────────────────────────────────────────
model Device {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  name         String    @default("Kasse")
  tokenHash    String    @unique // sha256 af enheds-token (cookie)
  lastSeenAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())
  stampsGiven  Stamp[]   @relation("DeviceStamps")

  @@index([businessId])
}

// Kortvarig parringskode: ejeren genererer den, personalet indtaster den paa
// enheden. Engangsbrug, udloeber efter faa minutter.
model DevicePairingCode {
  id         String    @id @default(cuid())
  businessId String
  business   Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  codeHash   String    @unique // sha256 af koden
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@index([businessId])
}

// ─────────────────────────────────────────────────────────────
// Bruger (kun virksomheder logger ind, aldrig kunder)
// Auth.js-felterne (name, emailVerified, image, accounts, sessions)
// er tilfoejet for magic link via Resend.
// ─────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified DateTime?
  image         String?
  businessId    String
  business      Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  accounts      Account[]
  sessions      Session[]
  stampsGiven   Stamp[]   @relation("StaffStamps")

  @@index([businessId])
}

// Auth.js standardmodeller
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─────────────────────────────────────────────────────────────
// Stempelkort (skabelon defineret af virksomheden)
// ─────────────────────────────────────────────────────────────

model Card {
  id             String         @id @default(cuid())
  businessId     String
  business       Business       @relation(fields: [businessId], references: [id], onDelete: Cascade)
  stampsRequired Int            @default(10) // 4 til 12
  rewardText     String
  stampIcon      String         @default("coffee") // coffee, scissors, croissant, heart, star, custom
  active         Boolean        @default(true)
  customerCards  CustomerCard[]
  campaigns      Campaign[]
  createdAt      DateTime       @default(now())

  @@index([businessId])
}

// ─────────────────────────────────────────────────────────────
// Kundens eksemplar af et kort
// ─────────────────────────────────────────────────────────────

model CustomerCard {
  id             String               @id @default(cuid())
  cardId         String
  card           Card                 @relation(fields: [cardId], references: [id], onDelete: Cascade)
  serial         String               @unique // bruges i pass og stregkode
  authToken      String               @unique // hemmeligt, til Wallet web service
  stamps         Int                  @default(0)
  completedCount Int                  @default(0)
  // Livstidstaeller: samlet antal stempler kunden NOGENSINDE har optjent hos
  // butikken. Kortet (stamps) nulstilles ved fuldt kort, men denne goer aldrig.
  // Taelles atomisk op ved hver stempling; backfilles fra sum(Stamp.multiplier).
  // Fundament for milepaele, stamkunde-status og win-back senere.
  lifetimeStamps Int                  @default(0)
  contactEmail   String? // valgfrit
  stampsLog      Stamp[]
  redemptions    Redemption[]
  walletRegs     WalletRegistration[]
  createdAt      DateTime             @default(now())
  lastStampAt    DateTime?

  @@index([cardId])
  // Statistik scoper alt paa cardId og filtrerer paa tid/livstid. Uden disse
  // scanner hver count/aggregate alle butikkens kortholder-raekker. Daekker
  // tilmeldinger over tid, aktive kunder (lastStampAt) og stamkunde-niveauer.
  @@index([cardId, createdAt])
  @@index([cardId, lastStampAt])
  @@index([cardId, lifetimeStamps])
}

enum StampMethod {
  KIOSK_QR
  STAFF_SCAN
  MANUAL
}

model Stamp {
  id             String       @id @default(cuid())
  customerCardId String
  customerCard   CustomerCard @relation(fields: [customerCardId], references: [id], onDelete: Cascade)
  // Denormaliseret butik: transaktionsloggen skal kunne svare paa "hvilken butik"
  // uden at joine gennem card. Billigt nu, dyrt at eftermontere. Backfilles.
  businessId     String?
  method         StampMethod
  tokenJti       String?
  multiplier     Int          @default(1)
  // Medarbejder-attribution: hvem gav stemplet. Kassen er enten en parret ENHED
  // eller ejerens LOGIN, saa vi logger begge (den relevante er sat). Vigtigt til
  // anti-snyd (opdage en medarbejder der stempler venner) og senere statistik.
  // NULL for kunde-QR og API-stempler samt historik foer attribution fandtes.
  staffUserId    String?
  staffUser      User?        @relation("StaffStamps", fields: [staffUserId], references: [id], onDelete: SetNull)
  staffDeviceId  String?
  staffDevice    Device?      @relation("DeviceStamps", fields: [staffDeviceId], references: [id], onDelete: SetNull)
  // Livstidstal EFTER denne transaktion (loebende sum). Lader os finde praecis
  // hvornaar en milepael (50/100/250) blev naaet uden omberegning. Billigt nu,
  // dyrt at eftermontere. Backfilles som running sum.
  lifetimeAfter  Int?
  // Udloeste denne stempling et fuldt kort? Billigt at logge nu, dyrt at udlede
  // bagud. Historik: false (kan ikke rekonstrueres praecist).
  filledCard     Boolean      @default(false)
  // Fremtidssikring til per-butik statistik (lokations-model paa roadmap Q1 2027).
  // Ingen Location-tabel eller logik endnu - kun feltet, saa historik ikke gaar
  // tabt, naar featuren bygges.
  locationId     String?
  createdAt      DateTime     @default(now())

  // Et token maa bruges een gang PR. KORT. NULL-jti'er (personale/API) kolliderer
  // aldrig, da NULL regnes som distinkt i Postgres.
  @@unique([tokenJti, customerCardId])
  @@index([customerCardId])
  // Tids-vinduer i statistik (i dag/uge/14 dage) + ugebrev-cron: dette indeks
  // daekker baade relations-semi-joinet og createdAt-range i eet scan.
  @@index([customerCardId, createdAt])
  // Per-butik-analyser (milepaele, win-back, medarbejder-moenstre) over tid.
  @@index([businessId, createdAt])
}

model Redemption {
  id             String       @id @default(cuid())
  customerCardId String
  customerCard   CustomerCard @relation(fields: [customerCardId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([customerCardId])
  // Tids-vinduer (indloesninger seneste 30 dage) + avgDaysToFull-window-query.
  @@index([customerCardId, createdAt])
}

enum CampaignType {
  DOUBLE_STAMP
  WELCOME_BONUS
}

model Campaign {
  id       String       @id @default(cuid())
  cardId   String
  card     Card         @relation(fields: [cardId], references: [id], onDelete: Cascade)
  type     CampaignType
  startsAt DateTime
  endsAt   DateTime

  @@index([cardId])
}

model WalletRegistration {
  id              String       @id @default(cuid())
  customerCardId  String
  customerCard    CustomerCard @relation(fields: [customerCardId], references: [id], onDelete: Cascade)
  deviceLibraryId String
  pushToken       String

  @@unique([customerCardId, deviceLibraryId])
  @@index([customerCardId])
  // Apple poller enheds-endpointet pr. enhed og filtrerer paa deviceLibraryId
  // alene. Uden dette indeks faldt det opslag tilbage til fuld scan (unique'ens
  // foerste kolonne er customerCardId), som vokser med antallet af registreringer.
  @@index([deviceLibraryId])
}

model AuditLog {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  action     String // STAMP, REDEEM, PIN_FAIL, FLAGGED
  detail     Json
  ip         String?
  createdAt  DateTime @default(now())

  @@index([businessId])
  @@index([businessId, action])
  // "Seneste aktivitet": where businessId order by createdAt desc take N.
  @@index([businessId, createdAt])
}

// DB-backet rate limit til magic-link-afsendelse (fail-closed), saa email-
// bombning ogsaa er bremset hvis Redis falder. scope = "login-email" osv.
model SendThrottle {
  id          String   @id @default(cuid())
  scope       String
  key         String
  count       Int      @default(0)
  windowStart DateTime @default(now())

  @@unique([scope, key])
}

// Personale-PIN forsoeg/laasning. DB-backet (ikke kun Redis), saa laasningen
// aldrig kan omgaas ved et Redis-nedbrud. lockId er IP (eller enheds-id).
model PinAttempt {
  id          String    @id @default(cuid())
  businessId  String
  lockId      String
  fails       Int       @default(0)
  lockedUntil DateTime?
  updatedAt   DateTime  @updatedAt

  @@unique([businessId, lockId])
}
